<?xml version="1.0" encoding="utf-8"?>
<!-- Widget grande: Resumen del Semestre con barras de progreso -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_resumen_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_resumen_background"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Resumen del Semestre"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_periodo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-1"
            android:textSize="11sp"
            android:textColor="#FFFFFFFF"
            android:alpha="0.8" />
    </LinearLayout>

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center">

        <!-- Promedio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_resumen_promedio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Promedio"
                android:textSize="10sp"
                android:textColor="#FFFFFFFF"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- Materias -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_resumen_materias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Materias"
                android:textSize="10sp"
                android:textColor="#FFFFFFFF"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- Aprobadas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_resumen_aprobadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FF66BB6A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aprobando"
                android:textSize="10sp"
                android:textColor="#FFFFFFFF"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- En riesgo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_resumen_riesgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFAB91" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En riesgo"
                android:textSize="10sp"
                android:textColor="#FFFFFFFF"
                android:alpha="0.7" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/pb_resumen_progreso"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="14dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress_bar" />

    <TextView
        android:id="@+id/tv_resumen_progreso_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0% del semestre evaluado"
        android:textSize="10sp"
        android:textColor="#FFFFFFFF"
        android:alpha="0.7"
        android:layout_marginTop="4dp" />

    <!-- Motivational message -->
    <TextView
        android:id="@+id/tv_resumen_mensaje"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#FFFFFFFF"
        android:alpha="0.9"
        android:layout_marginTop="8dp"
        android:textStyle="italic" />

</LinearLayout>
