<?xml version="1.0" encoding="utf-8"?>
<!--
    Gradify – Adaptive icon background.
    Degradado premium: azul profundo → violeta medio → teal.
    Ángulo 315° (de esquina inferior-izq a superior-der) refuerza idea de ascenso.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#FF0D1B4A"
        android:centerColor="#FF5C258D"
        android:endColor="#FF00838F" />
</shape>
